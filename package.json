{
  "name": "portifolio",
  "version": "0.1.0",
  "private": true,
  "author": {
    "name": "Victor",
    "email": "victorrony89@gmail.com",
    "url": "https://github.com/victorrony"
  },
  "description": "A personal portfolio website built with Next.js, React, and Tailwind CSS.",
  "keywords": [
    "portfolio",
    "nextjs",
    "react",
    "tailwindcss",
    "web development",
    "personal website"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/victorrony/portifolio"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "optimize:images": "node scripts/optimize-images.js",
    "analyze": "ANALYZE=true next build",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsc --noEmit",
    "prepare": "husky"
  },
  "dependencies": {
    "@emailjs/browser": "^4.4.1",
    "@react-three/drei": "^9.56.24",
    "@react-three/fiber": "^8.11.1",
    "animejs": "^4.3.6",
    "eslint": "8.36.0",
    "eslint-config-next": "13.2.4",
    "framer-motion": "^12.5.0",
    "gsap": "^3.13.0",
    "lenis": "^1.3.21",
    "next": "13.2.4",
    "nodemailer": "^7.0.3",
    "prop-types": "^15.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^4.8.0",
    "react-parallax-tilt": "^1.7.286",
    "react-vertical-timeline-component": "^3.5.3",
    "three": "^0.175.0"
  },
  "homepage": "https://portifolio-victorrony.vercel.app/",
  "bugs": {
    "url": "https://github.com/victorrony/portifolio/issues"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.9.1",
    "@types/react": "^19.2.2",
    "@types/three": "^0.180.0",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.14",
    "husky": "^9.1.7",
    "jsdom": "^27.0.1",
    "lint-staged": "^16.2.6",
    "postcss": "^8.4.21",
    "prettier": "^3.8.2",
    "sharp": "^0.34.4",
    "tailwindcss": "^3.3.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.1"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "npx eslint --fix",
      "npx prettier --write"
    ],
    "*.{json,md,css}": [
      "npx prettier --write"
    ]
  }
}
